# FairPay Environment Variables Example

# --- Database (Neon.tech - Free Tier) ---
# 1. Sign up at https://neon.tech
# 2. Create a new project and copy the connection string.
DATABASE_URL="postgresql://user:password@ep-cool-darkness-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"
# Direct URL is used for migrations (Prisma)
DIRECT_URL="postgresql://user:password@ep-cool-darkness-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# --- Cache & Queue (Upstash - Free Tier) ---
# 1. Sign up at https://upstash.com
# 2. Create a Redis database and copy the connection URL.
REDIS_URL="redis://default:your-password@your-db.upstash.io:6379"

# --- Blockchain (Sepolia Testnet) ---
# 1. Get an API key from Infura (https://infura.io) or Alchemy.
# 2. Get free test ETH from a Sepolia faucet.
NEXT_PUBLIC_SEPOLIA_RPC_URL="https://sepolia.infura.io/v3/YOUR_API_KEY"
DEPLOYER_PRIVATE_KEY="your_wallet_private_key"
VERIFIER_PRIVATE_KEY="your_backend_wallet_private_key"

# --- GitHub Integration ---
# 1. Create a GitHub App or Webhook in your repo settings.
GITHUB_WEBHOOK_SECRET="your_webhook_secret"

# --- Decentralized Storage (web3.storage) ---
# 1. Sign up at https://web3.storage
# 2. Create an API token.
WEB3_STORAGE_TOKEN="your_token"

# --- General ---
PORT=4000
NEXT_PUBLIC_IPFS_GATEWAY="https://w3s.link/ipfs"
ETHERSCAN_API_KEY="your_etherscan_api_key"
